<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BingoMAUI.ViewModels"
             x:Class="BingoMAUI.Views.BoardConfigPage"
             x:DataType="vm:BoardConfigPageViewModel"
             Title="{Binding PageTitle}">

    <ScrollView>
      <VerticalStackLayout Padding="20" Spacing="15">
     
        <Label Text="Board Name" FontSize="16" FontAttributes="Bold"/>
        <Entry Text="{Binding BoardNameInput}" Placeholder="Enter board name"/>
        
        <Label Text="Board Size" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Entry Text="{Binding BoardSizeInput}" 
               Placeholder="Enter size (e.g., 5 for 5x5)"
               Keyboard="Numeric"/>

     <Label Text="Cell Values" 
            FontSize="16" 
            FontAttributes="Bold" 
            Margin="0,10,0,0"/>
      <Label Text="Enter text for each cell in the board"
             FontSize="12"
             TextColor="Gray"
             Margin="0,0,0,10"/>

        <CollectionView ItemsSource="{Binding CellInputs}">
          <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:CellInputItem">
              <StackLayout Orientation="Horizontal" Spacing="10" Margin="0,5">
                <Label Text="{Binding Index, StringFormat='Cell {0}:'}" 
                       VerticalOptions="Center"
                       WidthRequest="80"/>
                <Entry Text="{Binding Value}" 
                       Placeholder="Enter cell text"
                       HorizontalOptions="FillAndExpand"/>
              </StackLayout>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Button Text="{Binding ApplyConfigButtonLabel}" 
                Command="{Binding ApplyConfigCommand}"
                Margin="0,20,0,0"
                HorizontalOptions="Fill"/>
      </VerticalStackLayout>
    </ScrollView>
</ContentPage>
